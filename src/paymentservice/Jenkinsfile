library 'shared_library_prod'

def svc = 'paymentservice'

ciPipeline(

    gitUrl: scm.userRemoteConfigs[0].url,

    serviceName: svc,

    servicePath: 'src/paymentservice',

    ecrRepo: '071882750948.dkr.ecr.us-east-2.amazonaws.com/11_microservices_demo/paymentservice',

    dockerCiPrebakedImage: 'nishant1994docker/currency-service-prebaked:trivy-owasp-sonar-ci-image',

    dockerCIPrebakedImageArgs: '-v /var/run/docker.sock:/var/run/docker.sock -v /usr/bin/docker:/usr/bin/docker --group-add 110',

    programmingLanguage: 'node',

    buildAndTestCmd: """
        set -e

        echo "=== NODE BUILD START ==="

        npm install

        npm run build || echo "No build script found, skipping"

        echo "=== NODE BUILD END ==="
    """,

    sonarCmd: """
        set -e

        echo "=== SONAR START ==="

        sonar-scanner \\
          -Dsonar.projectKey=paymentservice \\
          -Dsonar.sources=. \\
          -Dsonar.host.url=\$SONAR_HOST_URL \\
          -Dsonar.login=\$SONAR_AUTH_TOKEN

        echo "=== SONAR END ==="
    """,

    trivyScanCmd: """
        set -e

        echo "=== TRIVY SCAN START ==="

        trivy fs . \\
          --severity MEDIUM,LOW \\
          --format table \\
          --exit-code 0 \\
          --no-progress \\
          --cache-dir \$TRIVY_CACHE_DIR \\
          --output trivy-report.txt

        echo "=== TRIVY SCAN END ==="
    """,

    jUnitReportPath: '',

    archiveReports: 'trivy-report.txt'
)