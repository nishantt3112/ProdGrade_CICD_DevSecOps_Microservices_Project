library 'shared_library_prod'

def svc = 'shoppingassistantservice'

ciPipeline(

    gitUrl: scm.userRemoteConfigs[0].url,

    serviceName: svc,

    servicePath: 'src/shoppingassistantservice',

    ecrRepo: '071882750948.dkr.ecr.us-east-2.amazonaws.com/11_microservices_demo/shoppingassistantservice',

    dockerCiPrebakedImage: 'nishant1994docker/email-service-prebaked:trivy-owasp-sonar-awscli-docker-ci-image',

    dockerCIPrebakedImageArgs: '-v /var/run/docker.sock:/var/run/docker.sock -v /usr/bin/docker:/usr/bin/docker --group-add 110',

    programmingLanguage: 'python',

    buildAndTestCmd: """
        set -e

        echo "=== PYTHON BUILD START ==="

        python3 -m pip install --upgrade pip
        pip install -r requirements.txt

        echo "Build step completed (no compilation needed for Python)"

        echo "=== PYTHON BUILD END ==="
    """,

    sonarCmd: """
        set -e

        echo "=== SONAR START ==="

        sonar-scanner \\
          -Dsonar.projectKey=Shoppingassistantservice \\
          -Dsonar.sources=. \\
          -Dsonar.host.url=\$SONAR_HOST_URL \\
          -Dsonar.login=\$SONAR_AUTH_TOKEN

        echo "=== SONAR END ==="
    """,

    trivyScanCmd: """
        set -e

        echo "=== TRIVY SCAN START ==="

        trivy fs . \\
          --severity MEDIUM,LOW \\
          --format table \\
          --exit-code 0 \\
          --no-progress \\
          --cache-dir \$TRIVY_CACHE_DIR \\
          --output trivy-report.txt

        echo "=== TRIVY SCAN END ==="
    """,

    jUnitReportPath: '',

    archiveReports: 'trivy-report.txt'
)